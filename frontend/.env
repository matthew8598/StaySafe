# ── API mode ──────────────────────────────────────────────────────────────────
# true  → use mock data (no backend required)
# false → use real backend fetch calls
VITE_USE_MOCK_API=true

# ── Arduino mock ──────────────────────────────────────────────────────────────
# true  → simulate an Arduino posting sensor readings to the backend every 5 s
# Only useful when VITE_USE_MOCK_API=false (needs a running backend to receive data)
VITE_MOCK_ARDUINO=false

# ── Backend URL (defaults to http://localhost:3000/api) ───────────────────────
# VITE_API_URL=http://localhost:3000/api

# ── Device ID used by the frontend (defaults to 1) ───────────────────────────
# VITE_DEFAULT_DEVICE_ID=1

# ── Arduino mock device ID (defaults to 1) ───────────────────────────────────
# VITE_ARDUINO_DEVICE_ID=1

# ── Arduino mock send interval in ms (defaults to 5000) ──────────────────────
# VITE_ARDUINO_INTERVAL_MS=5000
